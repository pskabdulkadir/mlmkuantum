{
  "name": "@workspace/akngroup",
  "private": true,
  "type": "module",
  "pkg": {
    "assets": [
      "dist/spa/*"
    ],
    "scripts": [
      "dist/server/**/*.js"
    ]
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "build:client": "vite build",
    "build:server": "vite build --config vite.config.server.ts",
    "start:prod": "NODE_ENV=production node dist/server.cjs",
    "migrate": "node scripts/migrate-to-mongodb.js",
    "migrate:mongoose": "ts-node scripts/migrate-db-to-mongoose.ts",
    "migrate:users": "ts-node scripts/migrate-users.ts",
    "validate:users": "ts-node scripts/validate-users.ts",
    "migrate:transactions": "ts-node scripts/migrate-transactions.ts",
    "validate:transactions": "ts-node scripts/validate-transactions.ts",
    "format.fix": "prettier --write .",
    "typecheck": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist",
    "clean:build": "npm run clean && npm run build"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
